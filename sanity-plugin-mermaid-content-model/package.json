{
  "name": "sanity-plugin-mermaid-content-model",
  "version": "0.1.0",
  "private": true,
  "description": "Sanity Studio plugin that renders the content model as a Mermaid class diagram.",
  "keywords": [
    "sanity",
    "sanity-plugin",
    "mermaid",
    "content-model",
    "class-diagram",
    "schema"
  ],
  "license": "MIT",
  "author": "Andy Fitzgerald",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "source": "./src/index.tsx",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "pkg-utils build --strict --check --clean",
    "watch": "pkg-utils watch --strict",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19",
    "sanity": "^5"
  },
  "devDependencies": {
    "@sanity/pkg-utils": "^10",
    "@sanity/types": "^5.30.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^29.1.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sanity": "^5.30.0",
    "typescript": "^5.9.3",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "@sanity/icons": "^3.7.4",
    "@sanity/ui": "^3.2.0",
    "mermaid": "^11.15.0",
    "react-zoom-pan-pinch": "^4.0.3"
  }
}
