@prefix : <https://uxmethods.org/ontologies/uxmethods-core#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix uxm: <https://uxmethods.org/ontologies/uxmethods-core#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <https://uxmethods.org/ontologies/uxmethods-core#> .

<https://uxmethods.org/ontologies/uxmethods-core> rdf:type owl:Ontology ;
                                                   owl:versionIRI <https://uxmethods.org/ontologies/uxmethods-core/0.2.0> ;
                                                   dct:created "2025-12-26"^^xsd:date ;
                                                   dct:description "Core classes and properties for modeling UX Methods content."@en ;
                                                   dct:license <https://creativecommons.org/licenses/by/4.0/> ;
                                                   dct:modified "2026-05-18" ;
                                                   dct:publisher "Andy Fitzgerald Consulting, LLC"@en ;
                                                   dct:title "UX Methods Core Ontology"@en ;
                                                   rdfs:comment "Implementation note: curated terms/content can be separated into named graphs; this file defines only shared/core semantics."@en ;
                                                   owl:versionInfo "0.2.0" .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/terms/created
dct:created rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/description
dct:description rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/license
dct:license rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/modified
dct:modified rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/publisher
dct:publisher rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/title
dct:title rdf:type owl:AnnotationProperty .


###  https://uxmethods.org/ontologies/uxmethods-core#DesignNote
uxm:DesignNote rdf:type owl:AnnotationProperty ;
               rdfs:label "design note"@en .


#################################################################
#    Datatypes
#################################################################

###  http://www.w3.org/2001/XMLSchema#date
xsd:date rdf:type rdfs:Datatype .


#################################################################
#    Object Properties
#################################################################

###  https://uxmethods.org/ontologies/uxmethods-core#hasDownstreamMethod
uxm:hasDownstreamMethod rdf:type owl:ObjectProperty ;
                        rdfs:domain uxm:Method ;
                        rdfs:range uxm:Method ;
                        owl:propertyChainAxiom ( uxm:producesOutput
                                                 [ owl:inverseOf uxm:usesInput
                                                 ]
                                               ) .


###  https://uxmethods.org/ontologies/uxmethods-core#hasUpstreamMethod
uxm:hasUpstreamMethod rdf:type owl:ObjectProperty ;
                      rdfs:domain uxm:Method ;
                      rdfs:range uxm:Method ;
                      owl:propertyChainAxiom ( uxm:usesInput
                                               [ owl:inverseOf uxm:producesOutput
                                               ]
                                             ) .


###  https://uxmethods.org/ontologies/uxmethods-core#producesOutput
uxm:producesOutput rdf:type owl:ObjectProperty ;
                   rdfs:subPropertyOf owl:topObjectProperty ;
                   rdfs:domain uxm:Method ;
                   rdfs:range <http://www.w3.org/2004/02/skos/core#Concept> .


###  https://uxmethods.org/ontologies/uxmethods-core#usesInput
uxm:usesInput rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf owl:topObjectProperty ;
              rdfs:domain uxm:Method ;
              rdfs:range <http://www.w3.org/2004/02/skos/core#Concept> .


#################################################################
#    Data properties
#################################################################

###  https://uxmethods.org/ontologies/uxmethods-core#canonicalSlug
uxm:canonicalSlug rdf:type owl:DatatypeProperty ;
                  rdfs:domain uxm:Resource ;
                  rdfs:range xsd:string ;
                  rdfs:comment "Stable slug/identifier used by UX Methods site routing."@en ;
                  rdfs:label "canonical slug"@en .


###  https://uxmethods.org/ontologies/uxmethods-core#status
uxm:status rdf:type owl:DatatypeProperty ;
           rdfs:domain uxm:Resource ;
           rdfs:range xsd:string ;
           rdfs:comment "Workflow/status string (e.g., draft, reviewed, deprecated). Consider later replacing with controlled concepts."@en ;
           rdfs:label "status"@en .


#################################################################
#    Classes
#################################################################

###  http://www.w3.org/2004/02/skos/core#Concept
<http://www.w3.org/2004/02/skos/core#Concept> rdf:type owl:Class .


###  https://uxmethods.org/ontologies/uxmethods-core#Method
uxm:Method rdf:type owl:Class ;
           rdfs:subClassOf uxm:Resource ;
           rdfs:comment "A UX research or design method (e.g., usability test, interview, card sort)."@en ;
           rdfs:label "Method"@en .


###  https://uxmethods.org/ontologies/uxmethods-core#Resource
uxm:Resource rdf:type owl:Class ;
             rdfs:comment "A publishable or referenceable UX Methods item (e.g., method page, guide, template, example)."@en ;
             rdfs:label "Resource"@en .


